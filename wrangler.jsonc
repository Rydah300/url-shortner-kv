{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "url-shortner-kv",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-27",
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
		"binding": "USER_NOTIFICATION",
		"id": "b0a9a884e1334f4eb002e3b0f8bb694c"
		}
	]
}
